---
export interface Props {
    adSlot: string;
}
import HorizontalAd from "./HorizontalAd.astro";
const isDev = import.meta.env.DEV;
const { adSlot } = Astro.props;
---

<div class="border-2 border-[var(--slate8)] p-2 rounded-md border-dashed relative" data-ad-box>
    <div
        class="absolute -top-[15px] left-[50%] translate-x-[-50%] px-1 bg-[var(--slate5)] rounded-md text-sm z-999"
        data-ad-label
        style={isDev ? "display:none" : undefined}
    >
        Advertisement
    </div>
    <div class="min-h-100px relative">
        {!isDev && <HorizontalAd adSlot={adSlot} />}

        <!-- Shown when the ad is blocked or no ad is served (in dev there is no ad at all). -->
        <a
            class="ad-fallback"
            data-ad-fallback
            href="mailto:me@jenuel.dev?subject=Advertise%20on%20jenuel.dev&body=Hi%20Jenuel%2C%20I'd%20like%20to%20advertise%20in%20this%20spot%20on%20your%20blog."
            style={isDev ? undefined : "display:none"}
        >
            <span class="ad-fallback-eyebrow">This spot is available</span>
            <span class="ad-fallback-title">Want to own this part of the website?</span>
            <span class="ad-fallback-cta">Contact me &rarr; me@jenuel.dev</span>
        </a>
    </div>
</div>

<style>
    .ad-fallback {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 100px;
        padding: 16px;
        text-align: center;
        text-decoration: none;
        border-radius: 6px;
        color: var(--slate11);
        transition: background 0.2s ease, color 0.2s ease;
    }

    .ad-fallback:hover {
        background: color-mix(in srgb, var(--primary) 8%, transparent);
    }

    .ad-fallback-eyebrow {
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: color-mix(in srgb, var(--slate11) 65%, transparent);
    }

    .ad-fallback-title {
        font-size: 15px;
        font-weight: 600;
        color: var(--slate12);
    }

    .ad-fallback-cta {
        font-size: 13px;
        font-weight: 600;
        color: var(--primary);
    }

    .ad-fallback:hover .ad-fallback-cta {
        text-decoration: underline;
    }
</style>

<script>
    // Reveal the "advertise here" fallback whenever an ad slot ends up empty —
    // either AdSense reported no ad to serve, or an ad blocker stopped it loading.
    function syncAdFallbacks() {
        document.querySelectorAll<HTMLElement>("[data-ad-box]").forEach((box) => {
            const fallback = box.querySelector<HTMLElement>("[data-ad-fallback]");
            if (!fallback) return;

            const label = box.querySelector<HTMLElement>("[data-ad-label]");
            const ins = box.querySelector<HTMLElement>("ins.adsbygoogle");

            // Show the fallback invite: collapse the empty <ins> (so it doesn't
            // leave a tall blank gap) and hide the "Advertisement" label, since
            // there's no ad to label.
            const showFallback = () => {
                fallback.style.display = "";
                if (ins) ins.style.display = "none";
                if (label) label.style.display = "none";
            };
            // A real ad filled the slot: hide the fallback, restore the ad and
            // the "Advertisement" label.
            const showAd = () => {
                fallback.style.display = "none";
                if (ins) ins.style.display = "block";
                if (label) label.style.display = "";
            };

            // No ad markup at all — dev build, or an ad blocker stripped the
            // <ins> from the DOM entirely. Show the invite.
            if (!ins) return showFallback();

            const evaluate = (final: boolean) => {
                const status = ins.getAttribute("data-ad-status");
                if (status === "filled") return showAd();
                if (status === "unfilled") return showFallback();

                // The AdSense script itself failed to load (its onerror fired) —
                // a blocker cut the request. Deterministic, so react immediately.
                if ((window as any).__adsBlocked === true) return showFallback();

                // Final backstop: covers blockers that *neuter* the script
                // instead of blocking the request — the script "loads" but no
                // ad ever renders and no status is ever set.
                if (final) {
                    const rendered = ins.offsetHeight > 0 && !!ins.querySelector("iframe");
                    if (!rendered) showFallback();
                }
            };

            // React the moment AdSense marks the slot filled/unfilled.
            new MutationObserver(() => evaluate(false)).observe(ins, {
                attributes: true,
                attributeFilter: ["data-ad-status"],
            });

            // Quick pass for a hard-blocked request, then a final backstop for
            // the neutered-script / genuinely-unfilled cases.
            setTimeout(() => evaluate(false), 1000);
            setTimeout(() => evaluate(true), 2800);
        });
    }

    syncAdFallbacks();
    // Re-run after Astro View Transitions navigations.
    document.addEventListener("astro:page-load", syncAdFallbacks);
</script>
