---
// @ts-nocheck
export interface Props {
    adSlot: string;
}
const { adSlot } = Astro.props;
---

<script is:inline
    async
    src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2268807726840190"
    crossorigin="anonymous"></script>
<ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-2268807726840190"
    data-ad-slot={adSlot}
    data-ad-format="auto"
    data-full-width-responsive="true"></ins>
<script is:inline>
    // Initialize ads on initial page load
    (adsbygoogle = window.adsbygoogle || []).push({});

    // Re-initialize ads after Astro View Transitions
    document.addEventListener('astro:page-load', () => {
        if (window.adsbygoogle) {
            const adElements = document.querySelectorAll('ins.adsbygoogle');
            adElements.forEach((ad) => {
                // Only push if not already initialized (check for data-ad-status)
                if (!ad.getAttribute('data-ad-status') || ad.getAttribute('data-ad-status') === 'unfilled') {
                    try {
                        (adsbygoogle = window.adsbygoogle || []).push({});
                    } catch (e) {
                        console.log('AdSense push error:', e);
                    }
                }
            });
        }
    });
</script>
