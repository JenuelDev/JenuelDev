---
// ThemeToggle — 6 color themes matching main site
---

<div class="theme-toggle">
    <button
        id="theme-toggle-btn"
        class="theme-toggle-btn"
        aria-label="Change theme"
        title="Change theme"
    >
        <span class="theme-toggle-swatch" id="active-swatch"></span>
    </button>

    <div class="theme-dropdown" id="theme-dropdown" role="menu">
        <p class="theme-dropdown-label">Theme</p>
        <div class="theme-grid">
            <button class="theme-item ti-greenLight" data-accent="greenLight" data-dark="true" title="Green Light" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
            <button class="theme-item ti-yellowOrange" data-accent="yellowOrange" data-dark="true" title="Yellow Orange" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
            <button class="theme-item ti-underTheSea" data-accent="underTheSea" data-dark="true" title="Under the Sea" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
            <button class="theme-item ti-NightBurns" data-accent="NightBurns" data-dark="true" title="Night Burns" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
            <button class="theme-item ti-lightBurn" data-accent="lightBurn" data-dark="false" title="Light Burn" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
            <button class="theme-item ti-brightMind" data-accent="brightMind" data-dark="false" title="Bright Mind" role="menuitem">
                <span class="swatch s1"></span>
                <span class="swatch s2"></span>
                <span class="swatch s3"></span>
            </button>
        </div>
    </div>
</div>

<script>
    const DARK_ACCENTS = ['greenLight', 'yellowOrange', 'underTheSea', 'NightBurns'];
    const ACCENT_PRIMARY: Record<string, string> = {
        greenLight: '#64ffdb',
        yellowOrange: '#f0a500',
        underTheSea: '#2aea5e',
        NightBurns: '#fc595f',
        lightBurn: '#b8005c',
        brightMind: '#4b5ebe',
    };

    function applyAccent(accent: string) {
        const isDark = DARK_ACCENTS.includes(accent);
        document.documentElement.setAttribute('data-accent', accent);
        if (isDark) {
            document.documentElement.classList.add('dark');
        } else {
            document.documentElement.classList.remove('dark');
        }
        localStorage.setItem('accent', accent);
        updateActiveSwatch(accent);
        updateActiveItems(accent);
    }

    function updateActiveSwatch(accent: string) {
        const el = document.getElementById('active-swatch');
        if (el) el.style.background = ACCENT_PRIMARY[accent] ?? '#64ffdb';
    }

    function updateActiveItems(accent: string) {
        document.querySelectorAll<HTMLElement>('.theme-item').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.accent === accent);
        });
    }

    function initToggle() {
        const btn = document.getElementById('theme-toggle-btn');
        const dropdown = document.getElementById('theme-dropdown');

        if (btn) {
            const fresh = btn.cloneNode(true) as HTMLElement;
            btn.parentNode?.replaceChild(fresh, btn);
            fresh.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdown?.classList.toggle('open');
            });
        }

        document.addEventListener('click', () => dropdown?.classList.remove('open'));

        document.querySelectorAll<HTMLElement>('.theme-item').forEach(item => {
            item.addEventListener('click', (e) => {
                e.stopPropagation();
                const accent = item.dataset.accent ?? 'greenLight';
                applyAccent(accent);
                dropdown?.classList.remove('open');
            });
        });

        const current = localStorage.getItem('accent') ?? 'greenLight';
        updateActiveSwatch(current);
        updateActiveItems(current);
    }

    initToggle();
    document.addEventListener('astro:page-load', initToggle);
</script>

<style>
    .theme-toggle {
        position: relative;
    }

    .theme-toggle-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 9999px;
        border: 2px solid var(--slate6);
        background: var(--slate2);
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.645, 0.045, 0.355, 1);
        box-sizing: border-box;
        padding: 0;
    }

    .theme-toggle-btn:hover {
        background: var(--slate3);
        border-color: var(--primary);
        transform: scale(1.05);
    }

    .theme-toggle-swatch {
        display: block;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--primary);
        transition: background 0.25s ease;
        box-shadow: 0 0 8px color-mix(in srgb, var(--primary) 50%, transparent);
    }

    .theme-dropdown {
        position: absolute;
        top: calc(100% + 0.625rem);
        right: 0;
        min-width: 180px;
        background: var(--slate2);
        border: 1px solid var(--slate6);
        border-radius: 12px;
        padding: 0.75rem;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-0.5rem) scale(0.97);
        transition: all 0.2s cubic-bezier(0.645, 0.045, 0.355, 1);
        z-index: 100;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.4);
    }

    .theme-dropdown.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }

    .theme-dropdown-label {
        margin: 0 0 0.5rem;
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--slate9);
    }

    .theme-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.5rem;
    }

    .theme-item {
        display: flex;
        flex-direction: column;
        gap: 3px;
        padding: 6px;
        border-radius: 8px;
        border: 1px solid transparent;
        background: var(--slate3);
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .theme-item:hover {
        border-color: var(--slate7);
        transform: translateY(-1px);
    }

    .theme-item.active {
        border-color: var(--primary);
        box-shadow: 0 0 0 1px var(--primary);
    }

    .theme-item .swatch {
        display: block;
        height: 12px;
        border-radius: 3px;
        width: 100%;
    }

    /* greenLight */
    .ti-greenLight .s1 { background: #0a192f; }
    .ti-greenLight .s2 { background: #64ffdb; }
    .ti-greenLight .s3 { background: #112240; }

    /* yellowOrange */
    .ti-yellowOrange .s1 { background: #222222; }
    .ti-yellowOrange .s2 { background: #f0a500; }
    .ti-yellowOrange .s3 { background: #303030; }

    /* underTheSea */
    .ti-underTheSea .s1 { background: #021921; }
    .ti-underTheSea .s2 { background: #2aea5e; }
    .ti-underTheSea .s3 { background: #042631; }

    /* NightBurns */
    .ti-NightBurns .s1 { background: #151515; }
    .ti-NightBurns .s2 { background: #fc595f; }
    .ti-NightBurns .s3 { background: #25251d; }

    /* lightBurn */
    .ti-lightBurn .s1 { background: #dcdcdc; }
    .ti-lightBurn .s2 { background: #b8005c; }
    .ti-lightBurn .s3 { background: #e9e9e9; }

    /* brightMind */
    .ti-brightMind .s1 { background: #ffffff; }
    .ti-brightMind .s2 { background: #4b5ebe; }
    .ti-brightMind .s3 { background: #e9e9e9; }
</style>
