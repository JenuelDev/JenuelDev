---
export const prerender = true;
---

<section class="hero">
    <div class="hero-inner">
        <p class="hero-eyebrow">Hi, my name is</p>
        <h1 class="hero-name">Jenuel Ganawed.</h1>
        <h2 class="hero-tagline">I build things for the web.</h2>
        <p class="hero-desc">
            Software developer, technical writer, and open-source enthusiast. This is where I share
            articles on programming, finance, and everything in between.
        </p>
        <div class="hero-actions">
            <a href="/programming" class="hero-btn-primary">Read Articles</a>
            <a href="https://jenuel.dev" target="_blank" rel="noopener" class="hero-btn-ghost">
                Visit Portfolio ↗
            </a>
        </div>
    </div>
</section>

<style>
    .hero {
        min-height: 60vh;
        display: flex;
        align-items: center;
        padding: 0 1.5rem;
        max-width: 900px;
        margin: 0 auto;
        padding-top: 100px;
    }

    .hero-inner {
        max-width: 640px;
    }

    .hero-eyebrow {
        margin: 0 0 0.75rem;
        color: var(--primary);
        font-family: 'Inter var', monospace;
        font-size: 1rem;
        letter-spacing: 0.04em;
    }

    .hero-name {
        margin: 0 0 0.25rem;
        color: var(--slate12);
        font-size: clamp(2.2rem, 6vw, 3.8rem);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.02em;
    }

    .hero-tagline {
        margin: 0 0 1.5rem;
        color: var(--slate9);
        font-size: clamp(1.5rem, 4vw, 2.6rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.01em;
    }

    .hero-desc {
        margin: 0 0 2.5rem;
        color: var(--slate10);
        font-size: 1rem;
        line-height: 1.7;
        max-width: 540px;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .hero-btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border: 1px solid var(--primary);
        border-radius: 4px;
        background: color-mix(in srgb, var(--primary) 10%, transparent);
        color: var(--primary);
        font-family: 'Inter var', monospace;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.25s cubic-bezier(0.645, 0.045, 0.355, 1);
        letter-spacing: 0.02em;
    }

    .hero-btn-primary:hover {
        background: color-mix(in srgb, var(--primary) 18%, transparent);
        transform: translateY(-2px);
        box-shadow: 0 4px 20px color-mix(in srgb, var(--primary) 20%, transparent);
    }

    .hero-btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border: 1px solid var(--slate6);
        border-radius: 4px;
        background: transparent;
        color: var(--slate10);
        font-family: 'Inter var', monospace;
        font-size: 0.875rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.25s cubic-bezier(0.645, 0.045, 0.355, 1);
        letter-spacing: 0.02em;
    }

    .hero-btn-ghost:hover {
        border-color: var(--primary);
        color: var(--primary);
        transform: translateY(-2px);
    }
</style>
