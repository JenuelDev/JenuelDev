---
export const prerender = true;
import { Icon } from "astro-icon/components";
---

<section class="w-100% sm:text-lg flex flex-col pt-5 my-10 mt-20">
    <div class="flex flex-col gap-5 items-center justify-center h-100% max-w-800px mx-auto">
        <div
            class="inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-full bg-gray-800/50 backdrop-blur-sm border border-gray-700/50"
        >
            <div class="w-2 h-2 rounded-full bg-blue-400 animate-pulse"></div>
            <span class="text-gray-300 text-xs sm:text-sm font-medium"> Welcome to my Blog </span>
        </div>

        <div class="flex items-center gap-3">
            <h1
                class="tracking-tight md:text-5xl sm:text-4xl text-2xl group flex pb-3 pt-1.5 px-2 bg-[var(--red3)] text-[var(--red10)] rounded-md"
            >
                <Icon name="tabler:device-laptop" class="mr-1" />
                digital
            </h1>
            <div class="md:text-lg text-sm text-secondary">clean, <br />maintainable code</div>
        </div>
        <div class="flex flex-wrap gap-3 items-center justify-center">
            <h1
                class="tracking-tight md:text-5xl sm:text-4xl text-2xl flex pb-3 pt-1.5 px-2 bg-[var(--orange3)] text-[var(--orange10)] rounded-md relative"
            >
                <div
                    class="absolute -left-4 md:-bottom-9 -bottom-6 animate-bounce animate-duration-2000"
                >
                    <div
                        class="p-1 rounded-lg backdrop-blur-sm border border-purple-500/20 text-purple-400 sm:text-lg text-sm flex gap-1 items-center"
                    >
                        <Icon name="tabler:chart-bubble-filled" /> Innovation
                    </div>
                </div>

                <Icon name="tabler:apps" class="mr-1" />
                software
            </h1>
            <h1
                class="tracking-tight md:text-5xl sm:text-4xl text-2xl flex pb-3 pt-1.5 px-2 bg-[var(--green3)] text-[var(--green10)] rounded-md relative"
            >
                <div
                    class="absolute -right-4 md:-top-6 -top-5 animate-bounce animate-duration-2500"
                >
                    <div
                        class="p-1 rounded-lg bg-blue-500/10 backdrop-blur-sm border border-blue-500/20 text-blue-400 sm:text-lg text-sm flex gap-1 items-center"
                    >
                        <Icon name="tabler:terminal-2" /> Clean Code
                    </div>
                </div>
                <Icon name="tabler:terminal-2" class="mr-1" />
                programmer
            </h1>
        </div>
        <div class="flex flex-wrap gap-3 items-center justify-center">
            <developer class="md:text-lg text-sm text-secondary text-right">
                building delightful <br /> developer experiences
            </developer>
            <h1
                class="tracking-tight md:text-5xl sm:text-4xl text-2xl flex pb-3 pt-1.5 px-2 bg-[var(--blue3)] text-[var(--blue10)] rounded-md"
            >
                <Icon name="tabler:devices-code" class="mr-1" />
                developer
            </h1>
        </div>
    </div>
</section>
