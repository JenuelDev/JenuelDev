---
// ThemeScript.astro - Inline script that runs immediately to prevent theme flash
// Must be placed first in <head>
---
<script is:inline>
  function applyTheme() {
    var DARK_ACCENTS = ['greenLight', 'yellowOrange', 'underTheSea', 'NightBurns'];

    var accent = localStorage.getItem('accent') || 'greenLight';
    var isDarkAccent = DARK_ACCENTS.indexOf(accent) !== -1;

    var isDark;
    if (isDarkAccent) {
      isDark = true;
    } else {
      var stored = localStorage.getItem('theme');
      isDark = stored === 'dark' || (stored !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches);
    }

    if (isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    document.documentElement.setAttribute('data-accent', accent);
  }

  applyTheme();
  document.addEventListener('astro:after-swap', applyTheme);
</script>
