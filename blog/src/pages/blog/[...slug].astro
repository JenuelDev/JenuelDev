---
import { Image } from "astro:assets";
import Layout from "../../layouts/default.astro";
import { supabase } from "../../lib/supabase";
import { Icon } from "astro-icon/components";
import HorizontalAdBox from "../../components/ads/HorizontalAdBox.astro";
import "../../assets/code-highlight/atom-one-dark.css";
const { slug } = Astro.params;
const isDev = import.meta.env.DEV;

const { data } = await supabase
    .from("blogs")
    .select(`*, user_profile(*)`)
    .eq("is_active", 1)
    .eq("slug", slug)
    .single();
const url = Astro.url;
const author = data ? data.user_profile : null;
---

<Layout
    title={data.title}
    description={data.summary}
    url={url.toString()}
    canonical={url.toString()}
    image={data.cover_img ??
        `https://og-image.jenuel.dev/api/og/generate?title=${data.title}&description=${data.summary}`}
    isBlog={true}
>
    <section
        id="main-content"
        class="w-full max-w-800px mx-auto px-5 sm:text-lg pt-20"
        data-id={data.id}
        data-is-dev={isDev ? "true" : "false"}
    >
        {
            data?.cover_img && (
                <Image
                    src={data.cover_img}
                    class="rounded-lg w-full mx-auto col-span-2"
                    width={800}
                    height={400}
                    loading="eager"
                    alt={data.title}
                />
            )
        }
        <h1 class="text-3xl font-bold pt-5">{data?.title}</h1>
        <p class="my-5 text-secondary">
            {data?.summary}
        </p>
        <div class="flex flex-wrap gap-3 mb-3">
            {
                data?.tags.map((tags: any) => (
                    <div v-for="tags in data.tags" class="tag tag-sm text-sm">
                        #{tags}
                    </div>
                ))
            }
        </div>
        <div class="text-lg mb-5">
            {
                author && (
                    <div v-if="author" class="mt-3 flex flex-wrap gap-2 items-center">
                        ✍️
                        <a
                            href={author.website ?? "#"}
                            class="decoration-none text-[var(--color)]"
                            target="_blank"
                            title="authors website"
                            aria-label="authors website"
                        >
                            {author.username ? (
                                <span class="text-size-20px hover:text-[var(--primary)]">
                                    {author.username}
                                </span>
                            ) : (
                                <span class="text-size-20px hover:text-[var(--primary)]">
                                    {author.first_name}
                                    {author.last_name}
                                </span>
                            )}
                        </a>
                        <div class="flex items-center gap-3 text-size-20px">
                            {author.facebook_username && (
                                <a
                                    href={`https://facebook.com/${author.facebook_username}`}
                                    title={`facebook ${author.facebook_username}`}
                                    target="_blank"
                                    aria-label="facebook"
                                >
                                    <Icon name="TablerBrandFacebookFilled" />
                                </a>
                            )}
                            {author.instagram_username && (
                                <a
                                    href={`https://instagram.com/${author.instagram_username}`}
                                    title={`instagram ${author.instagram_username}`}
                                    target="_blank"
                                    aria-label="instagram"
                                >
                                    <Icon name="TablerBrandInstagram" />
                                </a>
                            )}
                            {author.tiktok_username && (
                                <a
                                    v-if="author.tiktok_username"
                                    href={`https://tiktok.com/${author.tiktok_username}`}
                                    title={`tiktok ${author.tiktok_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="tiktok"
                                >
                                    <Icon name="TablerBrandTiktok" />
                                </a>
                            )}
                            {author.twitter_username && (
                                <a
                                    v-if="author.twitter_username"
                                    href={`https://twitter.com/${author.twitter_username}`}
                                    title={`twitter ${author.twitter_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="twitter"
                                >
                                    <Icon name="TablerBrandTwitterFilled" />
                                </a>
                            )}
                            {author.threads_username && (
                                <a
                                    href={`https://threads.net/${author.threads_username}`}
                                    title={`threads ${author.threads_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="threads"
                                >
                                    <Icon name="TablerBrandThreads" />
                                </a>
                            )}
                            {author.youtube_username && (
                                <a
                                    v-if="author.youtube_username"
                                    href={`https://youtube.com/${author.youtube_username}`}
                                    title={`youtube ${author.youtube_username}`}
                                    target="_blank"
                                    aria-label="youtube"
                                >
                                    <Icon name="TablerBrandYoutubeFilled" />
                                </a>
                            )}
                        </div>
                    </div>
                )
            }
            <span class="text-size-15px blog-date" data-date={data.created_at}></span>
        </div>

        <HorizontalAdBox adSlot="4295024492" />

        <div
            class="content-render mx-auto relative md:text-lg pt-5 px-1 text-secondary"
            set:html={data.content}
        />

        <div class="mt-2 mx-auto relative md:text-lg">
            <div class="pb-5">
                <hr />
            </div>
            <p class="mb-10">
                If you enjoy this article and would like to show your support, you can easily do so
                by buying me a coffee. Your contribution is greatly appreciated!
            </p>
            <a href="https://www.buymeacoffee.com/jenuel.dev" target="_blank">
                <img
                    src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png"
                    alt="Buy Me A Coffee"
                    style="height: 60px !important;width: 217px !important;"
                />
            </a>
        </div>
    </section>
</Layout>
<script>
    const dateEl = document.querySelector<HTMLElement>(".blog-date[data-date]");
    if (dateEl?.dataset.date) {
        const d = new Date(dateEl.dataset.date);
        const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        const month = months[d.getMonth()];
        const day = String(d.getDate()).padStart(2, "0");
        const year = d.getFullYear();
        let hours = d.getHours();
        const minutes = String(d.getMinutes()).padStart(2, "0");
        const ampm = hours >= 12 ? "PM" : "AM";
        hours = hours % 12 || 12;
        dateEl.textContent = `${month}. ${day}, ${year}. ${hours}:${minutes} ${ampm}`;
    }

    setTimeout(async () => {
        const MainContentElement = document.getElementById("main-content");
        const id = MainContentElement?.getAttribute("data-id");
        const isDev = MainContentElement?.getAttribute("data-is-dev");

        if (isDev !== "true") {
            fetch(`/increment-count?id=${id}`, { method: "GET" });
        }
    }, 5000);
</script>
<style>
    .content-render {
        img {
            width: 100%;
            margin-bottom: 20px;
        }

        strong {
            margin-right: 10px;
        }

        ol {
            padding-left: 10px;
            padding-bottom: 20px;
            list-style-type: decimal;
        }

        ul {
            padding-left: 10px;
            padding-bottom: 20px;
            list-style-type: disc;

            a {
                position: relative;
                color: var(--primary);

                &:before {
                    content: "";
                    height: 2px;
                    position: absolute;
                    bottom: -5px;
                    width: 0;
                    background-color: var(--primary);
                    transition: all 0.2s;
                }

                &:hover {
                    color: var(--primary);
                    background-color: transparent;

                    &::before {
                        width: 100%;
                    }
                }
            }

            li {
                p {
                    padding-bottom: 5px;
                    padding-top: 5px;
                }
            }
        }

        h1,
        h2,
        h3,
        h4,
        h5 {
            margin-bottom: 15px;
            margin-top: 30px;
            position: relative;
            font-weight: bold;
            color: var(--slate12);

            a {
                position: relative;
                color: var(--primary);

                &:hover {
                    text-decoration: underline;
                }
            }

            code {
                background-color: var(--slate3);
                padding: 0 5px;
                border-radius: 5px;
                color: var(--slate12);
            }
        }

        h2 {
            font-size: 1.5em;
        }

        h3 {
            font-size: 1.3em;
        }

        h4 {
            font-size: 1.2em;
        }

        h5 {
            font-size: 1em;
        }

        pre {
            background-color: var(--slate3);
            color: var(--slate12);
            position: relative;
            padding: 20px;
            border-radius: 10px;
            overflow-x: auto;
            transition: all 0.25s;
            margin-bottom: 30px;
        }

        /* Keep code blocks dark in light mode */
        :root:not(.dark) pre {
            background-color: #1e293b;
            color: #e2e8f0;
        }

        p {
            padding-bottom: 20px;
            padding-top: 10px;

            a {
                @apply px-[5px] border-b-2 border-slate-300 font-bold relative;

                &:hover {
                    --gradient-from-color: #ff76e1;
                    --gradient-to-color: #8fd3f4;
                    --gradient-color-stops: var(--gradient-from-color),
                        var(--gradient-to-color, rgba(162, 247, 182, 0));
                    background-image: linear-gradient(to right, var(--gradient-color-stops));
                    border-radius: 0.125rem;
                    font-size: 1.125rem;
                    overflow-wrap: break-word;
                    padding: 0.25rem 0.5rem;
                    color: black;
                }
            }

            code {
                background-color: var(--slate3);
                padding: 0 5px;
                border-radius: 5px;
                color: var(--slate12);
            }

            strong {
                color: var(--slate12);
            }
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0 2rem;
            font-size: 0.95rem;
            border: 1px solid color-mix(in srgb, var(--primary) 30%, var(--slate6));
            border-radius: 8px;
            overflow: hidden;
        }

        thead {
            background: color-mix(in srgb, var(--primary) 15%, var(--slate2));
        }

        thead th {
            padding: 0.75rem 1.25rem;
            text-align: left;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--primary);
            border-bottom: 2px solid color-mix(in srgb, var(--primary) 40%, var(--slate6));
            border-right: 1px solid color-mix(in srgb, var(--primary) 20%, var(--slate6));
        }

        thead th:last-child {
            border-right: none;
        }

        tbody tr {
            border-bottom: 1px solid color-mix(in srgb, var(--primary) 15%, var(--slate6));
            transition: background 0.15s ease;
        }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:nth-child(even) {
            background: color-mix(in srgb, var(--primary) 4%, var(--slate2));
        }

        tbody tr:hover {
            background: color-mix(in srgb, var(--primary) 10%, var(--slate2));
        }

        tbody td {
            padding: 0.7rem 1.25rem;
            color: var(--slate11);
            vertical-align: middle;
            border-right: 1px solid color-mix(in srgb, var(--primary) 15%, var(--slate6));
        }

        tbody td:last-child {
            border-right: none;
        }

        *::-webkit-scrollbar {
            height: 10px;
        }

        a {
            word-wrap: break-word;
            text-decoration: none;
            color: var(--orange);

            &:hover {
                background-color: var(--orange);
                color: black;
            }
        }
    }

    .sepia {
        .content-render {
            pre {
                color: white;
                background-color: rgb(20, 14, 14);
            }
        }
    }

    .light {
        .content-render {
            pre {
                color: white;
                background-color: rgb(20, 20, 20);
            }
        }
    }
</style>
