---
import { Image } from "astro:assets";
import Layout from "../../layouts/default.astro";
import { supabase } from "../../lib/supabase";
import { ogImageUrl } from "../../lib/og";
import { Icon } from "astro-icon/components";
import HorizontalAdBox from "../../components/ads/HorizontalAdBox.astro";
import dayjs from "dayjs";
import "../../assets/code-highlight/atom-one-dark.css";
const { slug } = Astro.params;
const isDev = import.meta.env.DEV;

const { data } = await supabase
    .from("blogs")
    .select(`*, user_profile(*)`)
    .eq("is_active", 1)
    .eq("slug", slug)
    .single();
const author = data ? data.user_profile : null;

// --- SEO ---------------------------------------------------------------
const SITE = "https://blog.jenuel.dev";
const canonicalUrl = new URL(Astro.url.pathname, SITE).href;

const authorName =
    author?.username ||
    [author?.first_name, author?.last_name].filter(Boolean).join(" ") ||
    "Jenuel Oras Ganawed";

const toISO = (value: any) => {
    if (!value) return undefined;
    const parsed = new Date(value);
    return isNaN(parsed.getTime()) ? undefined : parsed.toISOString();
};
const publishedTime = toISO(data.created_at);
const modifiedTime = toISO(data.updated_at) ?? publishedTime;

// Human-readable published date, rendered server-side so it's in the crawlable
// HTML (inside a <time> element) instead of being injected by client JS.
const displayDate = data.created_at ? dayjs(data.created_at).format("MMM. DD, YYYY. h:mm A") : "";

// cover image, or a generated social-share card (via the shared OG helper).
const ogImage = data.cover_img ?? ogImageUrl(data.title ?? "", data.summary ?? "");

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: data.title,
    description: data.summary,
    image: ogImage ? [ogImage] : undefined,
    datePublished: publishedTime,
    dateModified: modifiedTime,
    author: {
        "@type": "Person",
        name: authorName,
        url: author?.website ?? "https://jenuel.dev",
    },
    publisher: {
        "@type": "Organization",
        name: "Jenuel Dev",
        logo: { "@type": "ImageObject", url: "https://i.imgur.com/2q9zwKJ.png" },
    },
    mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
    keywords: Array.isArray(data.tags) ? data.tags.join(", ") : undefined,
};

const breadcrumbLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${SITE}/` },
        { "@type": "ListItem", position: 2, name: "Blog", item: `${SITE}/blog` },
        { "@type": "ListItem", position: 3, name: data.title, item: canonicalUrl },
    ],
};

// Guard against a stray "</script>" inside the JSON breaking the tag.
const jsonLdString = JSON.stringify([jsonLd, breadcrumbLd]).replace(/</g, "\\u003c");
---

<Layout
    title={data.title}
    description={data.summary}
    url={canonicalUrl}
    canonical={canonicalUrl}
    image={ogImage}
    isBlog={true}
    publishedTime={publishedTime}
    modifiedTime={modifiedTime}
    authorName={authorName}
    tags={data.tags}
>
    <Fragment slot="head">
        <script type="application/ld+json" is:inline set:html={jsonLdString} />
    </Fragment>
    <section
        id="main-content"
        class="w-full max-w-800px mx-auto px-5 sm:text-lg pt-20"
        data-id={data.id}
        data-is-dev={isDev ? "true" : "false"}
    >
        {
            data?.cover_img && (
                <Image
                    src={data.cover_img}
                    class="rounded-lg w-full mx-auto col-span-2"
                    width={800}
                    height={400}
                    loading="eager"
                    alt={data.title}
                />
            )
        }
        <h1 class="text-3xl font-bold pt-5">{data?.title}</h1>
        <p class="my-5 text-secondary">
            {data?.summary}
        </p>
        <div class="flex flex-wrap gap-3 mb-3">
            {
                data?.tags.map((tags: any) => (
                    <div v-for="tags in data.tags" class="tag tag-sm text-sm">
                        #{tags}
                    </div>
                ))
            }
        </div>
        <div class="text-lg mb-5">
            {
                author && (
                    <div v-if="author" class="mt-3 flex flex-wrap gap-2 items-center">
                        ✍️
                        <a
                            href={author.website ?? "#"}
                            class="decoration-none text-[var(--color)]"
                            target="_blank"
                            title="authors website"
                            aria-label="authors website"
                        >
                            {author.username ? (
                                <span class="text-size-20px hover:text-[var(--primary)]">
                                    {author.username}
                                </span>
                            ) : (
                                <span class="text-size-20px hover:text-[var(--primary)]">
                                    {author.first_name}
                                    {author.last_name}
                                </span>
                            )}
                        </a>
                        <div class="flex items-center gap-3 text-size-20px">
                            {author.facebook_username && (
                                <a
                                    href={`https://facebook.com/${author.facebook_username}`}
                                    title={`facebook ${author.facebook_username}`}
                                    target="_blank"
                                    aria-label="facebook"
                                >
                                    <Icon name="TablerBrandFacebookFilled" />
                                </a>
                            )}
                            {author.instagram_username && (
                                <a
                                    href={`https://instagram.com/${author.instagram_username}`}
                                    title={`instagram ${author.instagram_username}`}
                                    target="_blank"
                                    aria-label="instagram"
                                >
                                    <Icon name="TablerBrandInstagram" />
                                </a>
                            )}
                            {author.tiktok_username && (
                                <a
                                    v-if="author.tiktok_username"
                                    href={`https://tiktok.com/${author.tiktok_username}`}
                                    title={`tiktok ${author.tiktok_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="tiktok"
                                >
                                    <Icon name="TablerBrandTiktok" />
                                </a>
                            )}
                            {author.twitter_username && (
                                <a
                                    v-if="author.twitter_username"
                                    href={`https://twitter.com/${author.twitter_username}`}
                                    title={`twitter ${author.twitter_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="twitter"
                                >
                                    <Icon name="TablerBrandTwitterFilled" />
                                </a>
                            )}
                            {author.threads_username && (
                                <a
                                    href={`https://threads.net/${author.threads_username}`}
                                    title={`threads ${author.threads_username}`}
                                    class="text-[var(--color)]"
                                    target="_blank"
                                    aria-label="threads"
                                >
                                    <Icon name="TablerBrandThreads" />
                                </a>
                            )}
                            {author.youtube_username && (
                                <a
                                    v-if="author.youtube_username"
                                    href={`https://youtube.com/${author.youtube_username}`}
                                    title={`youtube ${author.youtube_username}`}
                                    target="_blank"
                                    aria-label="youtube"
                                >
                                    <Icon name="TablerBrandYoutubeFilled" />
                                </a>
                            )}
                        </div>
                    </div>
                )
            }
            <time class="text-size-15px blog-date" datetime={publishedTime}>{displayDate}</time>
        </div>

        <HorizontalAdBox adSlot="4295024492" />

        <div
            class="content-render mx-auto relative md:text-lg pt-5 px-1 text-secondary"
            set:html={data.content}
        />

        <div class="mt-2 mx-auto relative md:text-lg">
            <div class="pb-5">
                <hr />
            </div>
            <p class="mb-10">
                Thanks for reading! If you enjoyed this article and like this kind of content, you're
                always welcome to buy me a little coffee, but only if you'd like to. No pressure at all,
                and either way I'm truly grateful you stopped by. &#9749;
            </p>
            <a href="https://www.buymeacoffee.com/jenuel.dev" target="_blank">
                <img
                    src="https://cdn.buymeacoffee.com/buttons/v2/default-yellow.png"
                    alt="Buy Me A Coffee"
                    style="height: 60px !important;width: 217px !important;"
                />
            </a>
        </div>
    </section>
</Layout>
<script>
    setTimeout(async () => {
        const MainContentElement = document.getElementById("main-content");
        const id = MainContentElement?.getAttribute("data-id");
        const isDev = MainContentElement?.getAttribute("data-is-dev");

        if (isDev !== "true") {
            fetch(`/increment-count?id=${id}`, { method: "GET" });
        }
    }, 5000);
</script>
<style>
    .content-render {
        img {
            width: 100%;
            margin-bottom: 20px;
        }

        strong {
            margin-right: 10px;
        }

        ol {
            padding-left: 10px;
            padding-bottom: 20px;
            list-style-type: decimal;
        }

        ul {
            padding-left: 10px;
            padding-bottom: 20px;
            list-style-type: disc;

            a {
                position: relative;
                color: var(--primary);

                &:before {
                    content: "";
                    height: 2px;
                    position: absolute;
                    bottom: -5px;
                    width: 0;
                    background-color: var(--primary);
                    transition: all 0.2s;
                }

                &:hover {
                    color: var(--primary);
                    background-color: transparent;

                    &::before {
                        width: 100%;
                    }
                }
            }

            li {
                p {
                    padding-bottom: 5px;
                    padding-top: 5px;
                }
            }
        }

        h1,
        h2,
        h3,
        h4,
        h5 {
            margin-bottom: 15px;
            margin-top: 30px;
            position: relative;
            font-weight: bold;
            color: var(--slate12);

            a {
                position: relative;
                color: var(--primary);

                &:hover {
                    text-decoration: underline;
                }
            }

            code {
                background-color: var(--slate3);
                padding: 0 5px;
                border-radius: 5px;
                color: var(--slate12);
            }
        }

        h2 {
            font-size: 1.5em;
        }

        h3 {
            font-size: 1.3em;
        }

        h4 {
            font-size: 1.2em;
        }

        h5 {
            font-size: 1em;
        }

        pre {
            background-color: var(--slate3);
            color: var(--slate12);
            position: relative;
            padding: 20px;
            border-radius: 10px;
            overflow-x: auto;
            transition: all 0.25s;
            margin-bottom: 30px;

            /* Clearly visible horizontal scrollbar so readers can tell
               there's more code off to the right. Code blocks stay dark in
               every theme, so use light-on-dark scrollbar colors here. */
            scrollbar-width: thin; /* Firefox */
            scrollbar-color: rgba(255, 255, 255, 0.4) rgba(255, 255, 255, 0.1); /* thumb, track */

            &::-webkit-scrollbar {
                height: 12px;
            }

            &::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.08);
                border-radius: 10px;
            }

            &::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.3);
                border-radius: 10px;
                border: 3px solid transparent;
                background-clip: padding-box;
            }

            &::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.55);
                background-clip: padding-box;
            }
        }

        /* Keep code blocks dark in light mode */
        :root:not(.dark) pre {
            background-color: #1e293b;
            color: #e2e8f0;
        }

        p {
            padding-bottom: 20px;
            padding-top: 10px;

            a {
                @apply px-[5px] border-b-2 border-slate-300 font-bold relative;

                &:hover {
                    --gradient-from-color: #ff76e1;
                    --gradient-to-color: #8fd3f4;
                    --gradient-color-stops: var(--gradient-from-color),
                        var(--gradient-to-color, rgba(162, 247, 182, 0));
                    background-image: linear-gradient(to right, var(--gradient-color-stops));
                    border-radius: 0.125rem;
                    font-size: 1.125rem;
                    overflow-wrap: break-word;
                    padding: 0.25rem 0.5rem;
                    color: black;
                }
            }

            code {
                background-color: var(--slate3);
                padding: 0 5px;
                border-radius: 5px;
                color: var(--slate12);
            }

            strong {
                color: var(--slate12);
            }
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.5rem 0 2rem;
            font-size: 0.95rem;
            border: 1px solid color-mix(in srgb, var(--primary) 30%, var(--slate6));
            border-radius: 8px;
            overflow: hidden;
        }

        thead {
            background: color-mix(in srgb, var(--primary) 15%, var(--slate2));
        }

        thead th {
            padding: 0.75rem 1.25rem;
            text-align: left;
            font-weight: 700;
            font-size: 0.85rem;
            letter-spacing: 0.05em;
            text-transform: uppercase;
            color: var(--primary);
            border-bottom: 2px solid color-mix(in srgb, var(--primary) 40%, var(--slate6));
            border-right: 1px solid color-mix(in srgb, var(--primary) 20%, var(--slate6));
        }

        thead th:last-child {
            border-right: none;
        }

        tbody tr {
            border-bottom: 1px solid color-mix(in srgb, var(--primary) 15%, var(--slate6));
            transition: background 0.15s ease;
        }

        tbody tr:last-child {
            border-bottom: none;
        }

        tbody tr:nth-child(even) {
            background: color-mix(in srgb, var(--primary) 4%, var(--slate2));
        }

        tbody tr:hover {
            background: color-mix(in srgb, var(--primary) 10%, var(--slate2));
        }

        tbody td {
            padding: 0.7rem 1.25rem;
            color: var(--slate11);
            vertical-align: middle;
            border-right: 1px solid color-mix(in srgb, var(--primary) 15%, var(--slate6));
        }

        tbody td:last-child {
            border-right: none;
        }

        *::-webkit-scrollbar {
            height: 10px;
            width: 10px;
        }

        *::-webkit-scrollbar-track {
            background: color-mix(in srgb, var(--slate6) 18%, transparent);
            border-radius: 10px;
        }

        *::-webkit-scrollbar-thumb {
            background: color-mix(in srgb, var(--slate6) 55%, transparent);
            border-radius: 10px;
        }

        *::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        a {
            word-wrap: break-word;
            text-decoration: none;
            color: var(--orange);

            &:hover {
                background-color: var(--orange);
                color: black;
            }
        }
    }

    .sepia {
        .content-render {
            pre {
                color: white;
                background-color: rgb(20, 14, 14);
            }
        }
    }

    .light {
        .content-render {
            pre {
                color: white;
                background-color: rgb(20, 20, 20);
            }
        }
    }
</style>
