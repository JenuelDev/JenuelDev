---
import Header from "../components/Header.astro";
import ThemeScript from "../components/ThemeScript.astro";
import LoadingIndicator from "astro-loading-indicator/component";

interface Props {
    title: string;
    description?: string;
    url?: string;
    image?: string;
    isBlog?: boolean;
    canonical?: string | null | undefined;
}

const { title, description, url, image, canonical }: Props = Astro.props;
import "../assets/styles.scss";
import Footer from "../components/Footer.astro";
import { SEO } from "astro-seo";
const DES =
    description ?? "I build web apps that are engaging, accessible and scalable - JenuelDev";
const URL = url ?? "https://jenuel.dev";
const defaultImage = 'https://i.imgur.com/2q9zwKJ.png';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Theme script must be first to prevent flash -->
        <ThemeScript />
        
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/JenuelDev.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="google-adsense-account" content="ca-pub-2268807726840190" />
        <ClientRouter />
        <LoadingIndicator color="var(--c-blue-500)" height="5px" />
        <SEO
            title={title}
            description={DES}
            canonical={canonical ?? "https://www.jenuel.dev"}
            openGraph={{
                basic: {
                    title: title,
                    url: URL,
                    image: image ?? defaultImage,
                    type: "website",
                },
                optional: {
                    description: DES,
                    siteName: "JenuelDev",
                },
            }}
            twitter={{
                title: title,
                site: URL,
                card: "summary_large_image",
                creator: "@JenuelDev",
                description: DES,
                image: image ?? defaultImage,
                imageAlt: "JenuelDev",
            }}
        />
    </head>
    <body>
        <Header transition:persist />
        <slot />
        <Footer />
<div id="bmc-persist" transition:persist></div>
    </body>
</html>
<script>
    document.addEventListener("astro:page-load", () => {
        const isOnBlogPost = !!document.getElementById("main-content");
        const container = document.getElementById("bmc-persist");
        if (!container) return;

        const btn = document.getElementById("bmc-wbtn");
        if (btn) {
            if (btn.parentElement !== container) container.appendChild(btn);
            container.style.display = isOnBlogPost ? "" : "none";
        } else if (isOnBlogPost) {
            const script = document.createElement("script");
            script.setAttribute("data-name", "BMC-Widget");
            script.setAttribute("data-cfasync", "false");
            script.setAttribute("data-id", "jenuel.dev");
            script.setAttribute("data-description", "Support me on Buy me a coffee!");
            script.setAttribute("data-message", "");
            script.setAttribute("data-color", "#FF813F");
            script.setAttribute("data-position", "Right");
            script.setAttribute("data-x_margin", "18");
            script.setAttribute("data-y_margin", "18");
            script.src = "https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js";
            document.body.appendChild(script);

            const obs = new MutationObserver(() => {
                const newBtn = document.getElementById("bmc-wbtn");
                if (newBtn) {
                    container.appendChild(newBtn);
                    obs.disconnect();
                }
            });
            obs.observe(document.body, { childList: true });
        }
    });
</script>
<style is:global>
    :root .astro-loading-indicator {
        z-index: 999999999999;
    }
</style>
