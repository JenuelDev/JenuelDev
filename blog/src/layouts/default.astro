---
import Header from "../components/Header.astro";
import ThemeScript from "../components/ThemeScript.astro";
import LoadingIndicator from "astro-loading-indicator/component";

interface Props {
    title: string;
    titleTemplate?: string;
    description?: string;
    url?: string;
    image?: string;
    isBlog?: boolean;
    canonical?: string | null | undefined;
    publishedTime?: string;
    modifiedTime?: string;
    authorName?: string;
    tags?: string[];
    noindex?: boolean;
    nofollow?: boolean;
}

const {
    title,
    titleTemplate = "%s | Jenuel Dev",
    description,
    url,
    image,
    isBlog,
    canonical,
    publishedTime,
    modifiedTime,
    authorName,
    tags,
    noindex = false,
    nofollow = false,
}: Props = Astro.props;
import "../assets/styles.scss";
import Footer from "../components/Footer.astro";
import { SEO } from "astro-seo";

const SITE = "https://blog.jenuel.dev";
const DES = description ?? "I build apps that are engaging, accessible and scalable - JenuelDev";
// Self-canonicalize every page to its real blog.jenuel.dev URL unless the
// caller overrides it. The old hard-coded jenuel.dev / www.jenuel.dev fallback
// told Google the blog was a duplicate of the separate portfolio site.
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE).href;
const ogUrl = url ?? canonicalUrl;
const defaultImage = "https://i.imgur.com/2q9zwKJ.png";
const ogImage = image ?? defaultImage;
const ogType = isBlog ? "article" : "website";
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Theme script must be first to prevent flash -->
        <ThemeScript />

        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/JenuelDev.ico" />
        <meta name="generator" content={Astro.generator} />
        <slot name="head" />
        <LoadingIndicator color="var(--c-blue-500)" height="5px" />
        <SEO
            title={title}
            titleTemplate={titleTemplate}
            noindex={noindex}
            nofollow={nofollow}
            description={DES}
            canonical={canonicalUrl}
            openGraph={{
                basic: {
                    title: title,
                    url: ogUrl,
                    image: ogImage,
                    type: ogType,
                },
                optional: {
                    description: DES,
                    siteName: "JenuelDev",
                    locale: "en_US",
                },
                ...(isBlog
                    ? {
                          article: {
                              publishedTime: publishedTime,
                              modifiedTime: modifiedTime ?? publishedTime,
                              authors: authorName ? [authorName] : undefined,
                              tags: tags,
                          },
                      }
                    : {}),
            }}
            twitter={{
                title: title,
                site: "@JenuelDev",
                card: "summary_large_image",
                creator: "@JenuelDev",
                description: DES,
                image: ogImage,
                imageAlt: "JenuelDev",
            }}
            extend={{
                link: [
                    {
                        rel: "alternate",
                        type: "application/rss+xml",
                        title: "Jenuel.Dev - Articles",
                        href: `${SITE}/rss.xml`,
                    },
                    { rel: "sitemap", type: "application/xml", href: `${SITE}/sitemap.xml` },
                ],
                meta: [{ name: "author", content: "Jenuel Oras Ganawed" }],
            }}
        />
    </head>
    <body>
        <Header transition:persist />
        <slot />
        <Footer />
        <script
            is:inline
            data-name="BMC-Widget"
            data-cfasync="false"
            data-id="jenuel.dev"
            data-description="Support me on Buy me a coffee!"
            data-message=""
            data-color="#26B0A1"
            data-position="Right"
            data-x_margin="18"
            data-y_margin="18"
            src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"></script>
        <style is:global>
            :root .astro-loading-indicator {
                z-index: 999999999999;
            }

            #bmc-wbtn {
                background-color: var(--primary) !important;
                z-index: 999999 !important;
            }
        </style>
    </body>
</html>
