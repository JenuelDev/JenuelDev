---
import Header from "../components/Header.astro";
import ThemeScript from "../components/ThemeScript.astro";
import LoadingIndicator from "astro-loading-indicator/component";

interface Props {
    title: string;
    description?: string;
    url?: string;
    image?: string;
    isBlog?: boolean;
    canonical?: string | null | undefined;
}

const { title, description, url, image, canonical }: Props = Astro.props;
import "../assets/styles.scss";
import Footer from "../components/Footer.astro";
import { SEO } from "astro-seo";
const DES = description ?? "I build apps that are engaging, accessible and scalable - JenuelDev";
const URL = url ?? "https://jenuel.dev";
const defaultImage = "https://i.imgur.com/2q9zwKJ.png";
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Theme script must be first to prevent flash -->
        <ThemeScript />

        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/JenuelDev.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="google-adsense-account" content="ca-pub-2268807726840190" />
        <LoadingIndicator color="var(--c-blue-500)" height="5px" />
        <SEO
            title={title}
            description={DES}
            canonical={canonical ?? "https://www.jenuel.dev"}
            openGraph={{
                basic: {
                    title: title,
                    url: URL,
                    image: image ?? defaultImage,
                    type: "website",
                },
                optional: {
                    description: DES,
                    siteName: "JenuelDev",
                },
            }}
            twitter={{
                title: title,
                site: URL,
                card: "summary_large_image",
                creator: "@JenuelDev",
                description: DES,
                image: image ?? defaultImage,
                imageAlt: "JenuelDev",
            }}
        />
    </head>
    <body>
        <Header transition:persist />
        <slot />
        <Footer />
        <script
            is:inline
            data-name="BMC-Widget"
            data-cfasync="false"
            data-id="jenuel.dev"
            data-description="Support me on Buy me a coffee!"
            data-message=""
            data-color="#26B0A1"
            data-position="Right"
            data-x_margin="18"
            data-y_margin="18"
            src="https://cdnjs.buymeacoffee.com/1.0.0/widget.prod.min.js"></script>
        <style is:global>
            :root .astro-loading-indicator {
                z-index: 999999999999;
            }

            #bmc-wbtn {
                background-color: var(--primary) !important;
                z-index: 999999 !important;
            }
        </style>
    </body>
</html>
